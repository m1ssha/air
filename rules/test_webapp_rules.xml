<?xml version="1.0" encoding="utf-8"?>
<group name="test_webapp,">
  <rule id="100001" level="0">
    <match>/buggy/</match>
    <description>Buggy app request detected</description>
  </rule>

  <rule id="100002" level="5">
    <if_sid>100001</if_sid>
    <match>password</match>
    <description>Password parameter detected in request</description>
  </rule>

  <rule id="100003" level="10" frequency="3" timeframe="5">
    <if_matched_sid>100002</if_matched_sid>
    <same_source_ip />
    <description>Multiple suspicious buggy login requests from same IP</description>
  </rule>
</group>